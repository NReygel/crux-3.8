# Architecture
CONFIG_64BIT=y
CONFIG_X86_64=y
CONFIG_X86=y

# Basic scheduler & timing
CONFIG_HZ_1000=y
CONFIG_SCHED_AUTOGROUP=y
CONFIG_PREEMPT_VOLUNTARY=y

# Intel CPU features
CONFIG_MSR=y
CONFIG_X86_INTEL_PSTATE=y
CONFIG_CPU_FREQ=y
CONFIG_CPU_IDLE=y

# ACPI / laptop support
CONFIG_ACPI=y
CONFIG_ACPI_SLEEP=y
CONFIG_ACPI_BATTERY=y
CONFIG_ACPI_LAPTOP=y
CONFIG_ACPI_PROCESSOR=y
CONFIG_PM=y
CONFIG_PM_AUTOSLEEP=y

# IOMMU
CONFIG_INTEL_IOMMU=y
CONFIG_IOMMU_SUPPORT=y

# Memory
CONFIG_BLK_DEV_NVM=y
CONFIG_BLK_DEV_NVME=y
CONFIG_BLK_DEV_NVME_CORE=y

# PCI / Hotplug
CONFIG_PCI=y
CONFIG_PCI_IOV=y
CONFIG_PCI_MSI=y
CONFIG_PCIEPORTBUS=y
CONFIG_HOTPLUG_PCIE_VALO=y

# Graphics – Intel iGPU (DRM/KMS)
CONFIG_DRM=y
CONFIG_DRM_KMS_HELPER=y
CONFIG_DRM_I915=y
CONFIG_DRM_I915_ENABLE_GUC=y
CONFIG_DRM_I915_ENABLE_HUC=y
CONFIG_DRM_FBDEV_EMULATION=y

# Disable nouveau + framebuffer for NVIDIA proprietary
# CONFIG_DRM_NOUVEAU is not set
# CONFIG_FB_NVIDIA is not set

# Input devices (touchpad, keyboard, touch)
CONFIG_INPUT=y
CONFIG_INPUT_PCSPKR=y
CONFIG_INPUT_KEYBOARD=y
CONFIG_INPUT_MOUSE=y
CONFIG_INPUT_TOUCHPAD=y
CONFIG_INPUT_JOYSTICK=y

# HID
CONFIG_HID=y
CONFIG_HID_GENERIC=y
CONFIG_HID_MULTITOUCH=y
CONFIG_I2C_HID=y
CONFIG_I2C_HID_REGISTERS=y

# USB support
CONFIG_USB_SUPPORT=y
CONFIG_USB_XHCI_HCD=y
CONFIG_USB_XHCI_PCI=y
CONFIG_USB_EHCI_HCD=y
CONFIG_USB_EHCI_PCI=y
CONFIG_USB_OHCI_HCD=y
CONFIG_USB_OHCI_HCD_PCI=y
CONFIG_USB_STORAGE=y
CONFIG_USB_UAS=y

# Networking
CONFIG_NET=y
CONFIG_NET_CORE=y
CONFIG_ETHERNET=y
CONFIG_PCI_ETHER=y
CONFIG_WLAN=y
CONFIG_BT=y
CONFIG_BT_HCIBTUSB=y
CONFIG_BT_HCIBTINTEL=y

# Audio – Realtek HD
CONFIG_SND=y
CONFIG_SND_HDA_INTEL=y
CONFIG_SND_HDA_CODEC_REALTEK=y
CONFIG_SND_PCM_OSS=y
CONFIG_SND_MIXER_OSS=y

# Filesystems
CONFIG_EXT4_FS=y
CONFIG_FAT_FS=y
CONFIG_NTFS_FS=y
CONFIG_BTRFS_FS=y

# Swap / RAM
CONFIG_SWAP=y
CONFIG_TMPFS=y

# Containers / Namespaces (optional)
CONFIG_CGROUPS=y
CONFIG_NAMESPACES=y

# Debug info for modules (optional, can be off)
# CONFIG_DEBUG_KERNEL is not set
